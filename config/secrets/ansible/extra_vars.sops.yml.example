mailserver:
  domain: example.com
  hostname: mail.example.com
  postmaster_email: postmaster@example.com
  acme_email: admin@example.com

platform_domains:
  primary: example.com
  dev: dev.example.com
  mail: example.com

# Deprecated compatibility alias. Prefer platform_domains.dev.
dev_domain_secret: dev.example.com

# Canonical DNS source for new VM provisioning via iac-wrapper.
# Compatibility fallback still exists for pihole.ip_address.
dns:
  server:
    ip_address: "192.0.2.100"

# IP-адреса для прокси
nginx_proxy_ips:
  k8s_ingress: "192.0.2.10:443"
  gitlab_ssh: "192.0.2.11:22"
  proxmox_ssh: "192.0.2.12:22"
  wiki_http: "http://192.0.2.13:3000"
  plantuml_http: "http://192.0.2.14:18080"
  proxmox_https: "https://192.0.2.12:8006"
  gitlab_http: "192.0.2.11:80"
  harbor_http: "192.0.2.15:80"
  vault_http: "http://192.0.2.109:8200"

# Vault MVP backup settings. Keep unseal keys and root tokens out of SOPS.
# Canonical structure is nested under vault.*. Flat vault_* keys remain
# supported in the role for backward compatibility with older secrets files.
vault:
  backup:
    s3:
      enabled: false
      endpoint: "https://s3.minio.example.com"
      bucket: "vault-backups"
      prefix: "raft"
      create_bucket: true
      access_key: "vault-backup-access-key"
      secret_key: "vault-backup-secret-key"
    rclone:
      enabled: false
      target: "vaultgdrivecrypt:raft"
      config: |
        [gdrive]
        type = drive
        scope = drive
        token = {"access_token":"example","token_type":"Bearer","refresh_token":"example","expiry":"2099-01-01T00:00:00Z"}

        [vaultgdrivecrypt]
        type = crypt
        remote = gdrive:99_Archive/Backups/Vault/vault-backups
        password = obscured-password
        password2 = obscured-salt
  firewall:
    enabled: false
    allowed_api_sources:
      - "192.0.2.105"
