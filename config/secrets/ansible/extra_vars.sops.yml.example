mailserver:
  domain: example.com
  hostname: mail.example.com
  postmaster_email: postmaster@example.com
  acme_email: admin@example.com

dev_domain_secret: dev.example.com

# IP-адреса для прокси
nginx_proxy_ips:
  k8s_ingress: "10.10.10.10:443"
  gitlab_ssh: "10.10.10.11:22"
  proxmox_ssh: "10.10.10.12:22"
  wiki_http: "http://10.10.10.13:3000"
  plantuml_http: "http://10.10.10.14:18080"
  proxmox_https: "https://10.10.10.12:8006"
  gitlab_http: "10.10.10.11:80"
  harbor_http: "10.10.10.15:80"

# Vault MVP backup settings. Keep unseal keys and root tokens out of SOPS.
vault_backup_s3_enabled: false
vault_backup_s3_endpoint: "https://s3.minio.example.com"
vault_backup_s3_bucket: "vault-backups"
vault_backup_s3_prefix: "raft"
vault_backup_s3_access_key: "vault-backup-access-key"
vault_backup_s3_secret_key: "vault-backup-secret-key"
vault_backup_rclone_enabled: false
vault_backup_rclone_target: "gdrive-crypt:vault-backups"
