# Vault bootstrap example.
# Copy to bootstrap.sops.yml only when a future workflow starts consuming it.
# Do not store root tokens, unseal keys, or recovery keys here.

vault:
  api_addr: http://vault.example.com:8200
  snapshot:
    enabled: true
    local_retention_days: 14
    minio_bucket: vault-backups
    rclone_target: gdrive-crypt:vault-backups
