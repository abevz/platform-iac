# Example Ansible inventory
# Copy to static.ini and customize with your IPs and username:
#   cp static.ini.example static.ini

[proxmox_nodes]
# Your Proxmox host (FQDN or IP)
proxmox.example.com ansible_user=terraform

[nginx_proxies]
# Public reverse proxy host. Keep real hosts in local static.ini only.
nginx-proxy.example.com ansible_user=your-username

[nginx_proxies:vars]
primary_domain=example.com
dev_domain=dev.example.com

[mailservers]
# Укажите IP или FQDN вашего почтового сервера
mail.example.com ansible_user=your-username

[my_k8s_cp]
# Control plane node(s)
<K8S-CONTROL-PLANE-IP> ansible_user=your-username

[my_k8s_workers]
# Worker nodes
<K8S-WORKER-1-IP> ansible_user=your-username
<K8S-WORKER-2-IP> ansible_user=your-username
<K8S-WORKER-3-IP> ansible_user=your-username

[my_k8s_cluster:children]
my_k8s_cp
my_k8s_workers

[all:vars]
ansible_user=your-username

[workstation]
127.0.0.1 ansible_connection=local
