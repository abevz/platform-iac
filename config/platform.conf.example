# Platform IAC Configuration
# Copy this file to platform.conf and customize for your environment
#
# This file is sourced by tools/iac-wrapper.sh
# Add platform.conf to .gitignore (already done)

# --- SSH Configuration ---
# Path to SSH private key for Ansible connections
# Default: ${REPO_ROOT}/keys/deployment_key
SSH_KEY="${REPO_ROOT}/keys/deployment_key"

# --- Terraform/Tofu State Backend ---
# S3 bucket name for Terraform state (MinIO or AWS S3)
TF_STATE_BUCKET="terraform-state-example"
