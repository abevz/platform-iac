# /config/roles/minio_setup/templates/docker-compose.yml.j2
# File managed by Ansible.
services:
  minio:
    image: {{ rustfs_image }}
    container_name: minio-server
    restart: unless-stopped

    # NOTE:
    # These variables should be defined in your file
    # config/secrets/ansible/extra_vars.sops.yml
    # The minio.* names are kept as compatibility inputs for this replacement.
    environment:
      RUSTFS_VOLUMES: "/data"
      RUSTFS_ADDRESS: "{{ rustfs_address }}"
      RUSTFS_CONSOLE_ENABLE: "true"
      RUSTFS_CONSOLE_ADDRESS: "{{ rustfs_console_address }}"
      RUSTFS_ACCESS_KEY: "{{ minio.root_user | default('minioadmin') }}"
      RUSTFS_SECRET_KEY: "{{ minio.root_password | default('minioadmin') }}"

    ports:
      - "9000:9000" # S3 API
      - "9001:9001" # Console

    volumes:
      - "{{ minio_data_dir }}:/data"
      - "{{ minio_config_dir }}:/config"
      - "{{ rustfs_logs_dir }}:/logs"

    networks:
      - app-network

networks:
  app-network:
    driver: bridge
