{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "max(up{job=\"node-exporter\",instance=\"10.10.10.101:9100\"})", "refId": "A" }],
      "title": "Host",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "count(pve_guest_info)", "refId": "A" }],
      "title": "VM/CT Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "sum(node_systemd_unit_state{instance=\"10.10.10.101:9100\",state=\"failed\"} > 0) or vector(0)", "refId": "A" }],
      "title": "Failed Units",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "id": 16,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{instance=\"10.10.10.101:9100\",mode=\"idle\"}[5m])) * 100)", "refId": "A" }],
      "title": "CPU Used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "id": 17,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"10.10.10.101:9100\"} / node_memory_MemTotal_bytes{instance=\"10.10.10.101:9100\"})) * 100", "refId": "A" }],
      "title": "RAM Used",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 85 }, { "color": "red", "value": 92 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "max(100 * (1 - (node_filesystem_avail_bytes{instance=\"10.10.10.101:9100\",fstype!~\"tmpfs|overlay\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"10.10.10.101:9100\",fstype!~\"tmpfs|overlay\",mountpoint=\"/\"})))", "refId": "A" }],
      "title": "Disk Used /",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "mappings": [{ "type": "value", "options": { "-1": { "text": "N/A" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 7 }, { "color": "green", "value": 21 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "min((probe_ssl_earliest_cert_expiry - time()) / 86400) or vector(-1)", "refId": "A" }],
      "title": "Cert Days Left",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "sum(ALERTS{alertstate=\"firing\"}) or vector(0)", "refId": "A" }],
      "title": "Alerts Firing",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 7,
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{instance=\"10.10.10.101:9100\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "homelab", "refId": "A" }],
      "title": "CPU Trend",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 8,
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"10.10.10.101:9100\"} / node_memory_MemTotal_bytes{instance=\"10.10.10.101:9100\"})) * 100", "legendFormat": "homelab", "refId": "A" }],
      "title": "RAM Trend",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 9,
      "targets": [
        { "expr": "sum(rate(node_network_receive_bytes_total{instance=\"10.10.10.101:9100\",device!~\"lo|docker.*|veth.*\"}[5m]))", "legendFormat": "RX", "refId": "A" },
        { "expr": "sum(rate(node_network_transmit_bytes_total{instance=\"10.10.10.101:9100\",device!~\"lo|docker.*|veth.*\"}[5m]))", "legendFormat": "TX", "refId": "B" }
      ],
      "title": "Network I/O",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 10,
      "targets": [
        { "expr": "sum(rate(node_disk_read_bytes_total{instance=\"10.10.10.101:9100\",device!~\"loop.*|ram.*\"}[5m]))", "legendFormat": "Read", "refId": "A" },
        { "expr": "sum(rate(node_disk_written_bytes_total{instance=\"10.10.10.101:9100\",device!~\"loop.*|ram.*\"}[5m]))", "legendFormat": "Write", "refId": "B" }
      ],
      "title": "Disk I/O",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "id": 11,
      "targets": [
        { "expr": "avg by(chip, sensor) ((node_hwmon_temp_celsius{instance=\"10.10.10.101:9100\",sensor!~\"fan.*\"} > 0) and (node_hwmon_temp_celsius{instance=\"10.10.10.101:9100\",sensor!~\"fan.*\"} < 120))", "legendFormat": "{% raw %}{{chip}}{% endraw %} / {% raw %}{{sensor}}{% endraw %}", "refId": "A" }
      ],
      "title": "Temperatures",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "id": 12,
      "targets": [
        { "expr": "100 * pve_cpu_usage_ratio{instance=\"10.10.10.101\",id=~\"(qemu|lxc)/.*\"} * on(instance,id) group_left(name,type) pve_guest_info{instance=\"10.10.10.101\"}", "legendFormat": "{% raw %}{{name}}{% endraw %}", "refId": "A" }
      ],
      "title": "Proxmox VM CPU %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 13,
      "targets": [
        { "expr": "sum(node_systemd_unit_state{instance=\"10.10.10.101:9100\",state=\"failed\"} > 0) or vector(0)", "legendFormat": "failed units", "refId": "A" },
        { "expr": "max(up{job=\"pve-exporter\"})", "legendFormat": "pve target", "refId": "B" }
      ],
      "title": "Operator Signals",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 14,
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "{% raw %}{{alertname}}{% endraw %} ({% raw %}{{severity}}{% endraw %})",
          "refId": "A"
        }
      ],
      "title": "Alert Timeline",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "rpm" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "id": 15,
      "targets": [
        { "expr": "node_hwmon_fan_rpm{instance=\"10.10.10.101:9100\",chip=\"platform_asus_ec_sensors\",sensor=\"fan1\"}", "legendFormat": "VRM HS fan", "refId": "A" },
        { "expr": "node_hwmon_fan_rpm{instance=\"10.10.10.101:9100\",chip=\"platform_asus_ec_sensors\",sensor=\"fan2\"}", "legendFormat": "Chipset fan", "refId": "B" },
        { "expr": "node_hwmon_fan_rpm{instance=\"10.10.10.101:9100\",chip=\"platform_nct6775_656\",sensor=\"fan1\"}", "legendFormat": "NCT fan1", "refId": "C" },
        { "expr": "node_hwmon_fan_rpm{instance=\"10.10.10.101:9100\",chip=\"platform_nct6775_656\",sensor=\"fan2\"}", "legendFormat": "NCT fan2", "refId": "D" }
      ],
      "title": "Fan RPM",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 18,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "node_systemd_unit_state{instance=\"10.10.10.101:9100\",state=\"failed\"} > 0",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Failed Unit Details",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": false,
              "__name__": true,
              "cpu": true,
              "instance": false,
              "job": true,
              "state": false
            },
            "indexByName": {},
            "renameByName": {
              "Value": "failed",
              "instance": "host",
              "name": "unit"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 19,
      "targets": [
        { "expr": "100 * (pve_memory_usage_bytes{instance=\"10.10.10.101\",id=~\"(qemu|lxc)/.*\"} / pve_memory_size_bytes{instance=\"10.10.10.101\",id=~\"(qemu|lxc)/.*\"}) * on(instance,id) group_left(name,type) pve_guest_info{instance=\"10.10.10.101\"}", "legendFormat": "{% raw %}{{name}}{% endraw %}", "refId": "A" }
      ],
      "title": "Proxmox VM RAM %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "id": 20,
      "targets": [
        {
          "expr": "node_hwmon_temp_celsius{instance=\"10.10.10.101:9100\",chip=\"platform_asus_ec_sensors\",sensor=\"temp1\"}",
          "legendFormat": "Chipset temp (C)",
          "refId": "A"
        },
        {
          "expr": "node_hwmon_fan_rpm{instance=\"10.10.10.101:9100\",chip=\"platform_asus_ec_sensors\",sensor=\"fan2\"}",
          "legendFormat": "Chipset fan RPM",
          "refId": "B"
        }
      ],
      "title": "Noise / Thermal (Chipset)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "id": 21,
      "targets": [
        {
          "expr": "100 * (pve_disk_usage_bytes{instance=\"10.10.10.101\",id=~\"(qemu|lxc)/.*\"} / pve_disk_size_bytes{instance=\"10.10.10.101\",id=~\"(qemu|lxc)/.*\"}) * on(instance,id) group_left(name,type) pve_guest_info{instance=\"10.10.10.101\"}",
          "legendFormat": "{% raw %}{{name}}{% endraw %}",
          "refId": "A"
        }
      ],
      "title": "Proxmox VM Disk %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "id": 22,
      "targets": [
        {
          "expr": "topk(5, 100 * (pve_disk_usage_bytes{instance=\"10.10.10.101\",id=~\"(qemu|lxc)/.*\"} / pve_disk_size_bytes{instance=\"10.10.10.101\",id=~\"(qemu|lxc)/.*\"}) * on(instance,id) group_left(name,type) pve_guest_info{instance=\"10.10.10.101\"})",
          "legendFormat": "{% raw %}{{name}}{% endraw %}",
          "refId": "A"
        }
      ],
      "title": "Top 5 VM Disk %",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["homelab", "monitoring", "pulse"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Homelab Pulse",
  "uid": "homelab-overview",
  "version": 11
}
