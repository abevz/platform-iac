global:
  scrape_interval: 15s
  evaluation_interval: 30s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: node-exporter
    static_configs:
{% for target in monitoring_node_exporter_targets %}
      - targets: ["{{ target }}"]
{% endfor %}

  - job_name: pve-exporter
    metrics_path: /pve
    params:
      module: ["default"]
      cluster: ["1"]
      node: ["1"]
    static_configs:
      - targets: ["{{ monitoring_proxmox_target }}"]
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: pve-exporter:9221

{% for cluster in monitoring_k8s_clusters | default([]) %}
  - job_name: {{ cluster.name }}-nodes
    static_configs:
      - targets:
{% for ip in cluster.node_ips %}
          - "{{ ip }}:{{ monitoring_k8s_node_exporter_port | default(9100) }}"
{% endfor %}
        labels:
          cluster: {{ cluster.name }}

  - job_name: {{ cluster.name }}-kube-state-metrics
    static_configs:
      - targets:
          - "{{ cluster.node_ips[0] }}:{{ monitoring_k8s_kube_state_metrics_nodeport | default(30080) }}"
        labels:
          cluster: {{ cluster.name }}

{% if cluster.vault_k8s_role is defined and cluster.api_server is defined %}
  - job_name: {{ cluster.name }}-k8s-pods
    kubernetes_sd_configs:
      - role: pod
        api_server: https://{{ cluster.api_server }}:6443
        bearer_token_file: /etc/prometheus/k8s-tokens/{{ cluster.name }}.token
        tls_config:
          insecure_skip_verify: true
    relabel_configs:
      - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_scrape]
        action: keep
        regex: "true"
      - source_labels: [__meta_kubernetes_pod_annotation_prometheus_io_path]
        action: replace
        target_label: __metrics_path__
        regex: (.+)
      - source_labels: [__address__, __meta_kubernetes_pod_annotation_prometheus_io_port]
        action: replace
        regex: ([^:]+)(?::\d+)?;(\d+)
        replacement: $1:$2
        target_label: __address__
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: pod
      - target_label: cluster
        replacement: {{ cluster.name }}

  - job_name: {{ cluster.name }}-k8s-endpoints
    kubernetes_sd_configs:
      - role: endpoints
        api_server: https://{{ cluster.api_server }}:6443
        bearer_token_file: /etc/prometheus/k8s-tokens/{{ cluster.name }}.token
        tls_config:
          insecure_skip_verify: true
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_annotation_prometheus_io_scrape]
        action: keep
        regex: "true"
      - source_labels: [__meta_kubernetes_service_annotation_prometheus_io_path]
        action: replace
        target_label: __metrics_path__
        regex: (.+)
      - source_labels: [__address__, __meta_kubernetes_service_annotation_prometheus_io_port]
        action: replace
        regex: ([^:]+)(?::\d+)?;(\d+)
        replacement: $1:$2
        target_label: __address__
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace
      - source_labels: [__meta_kubernetes_service_name]
        target_label: service
      - target_label: cluster
        replacement: {{ cluster.name }}
{% endif %}

{% endfor %}
  - job_name: alertmanager
    static_configs:
      - targets: ["alertmanager:9093"]

{% if monitoring_jenkins_metrics_target_resolved | default('') | length > 0 %}
  - job_name: jenkins
    metrics_path: "{{ monitoring_jenkins_metrics_path_resolved }}"
    static_configs:
      - targets: ["{{ monitoring_jenkins_metrics_target_resolved }}"]
{% endif %}

  - job_name: blackbox-ssl
    metrics_path: /probe
    params:
      module: ["https_2xx"]
    static_configs:
{% for target in monitoring_blackbox_targets_effective | default(monitoring_blackbox_targets) %}
      - targets: ["{{ target }}"]
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115
